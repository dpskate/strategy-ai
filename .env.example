# Strategy AI — Environment Variables
# Copy this file to .env and fill in the values

# API security key for the backend
# If not set, the server runs in dev mode (no auth required)
STRATEGY_AI_API_KEY=

# OpenAI-compatible API key (passed per-request from the frontend, but can pre-set here)
# Used by the /generate and /pipeline endpoints
OPENAI_API_KEY=

# Claude / Anthropic API key (if using Claude models via the pipeline)
CLAUDE_API_KEY=
